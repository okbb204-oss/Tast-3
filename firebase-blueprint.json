{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile with authentication and progress data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "securityQuestion": { "type": "string" },
        "securityAnswer": { "type": "string" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "goal": { "type": "string" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "avatarLevel": { "type": "number" },
        "skillProgress": { "type": "object" }
      },
      "required": ["uid", "username", "securityQuestion", "securityAnswer"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User document storing personal data and progress."
    }
  }
}
